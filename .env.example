# ──────────────────────────────────────────────
#  Machino — Umgebungsvariablen
#  Kopiere diese Datei nach .env und passe sie an
# ──────────────────────────────────────────────

# Domain (für Traefik / Let's Encrypt)
APP_DOMAIN=machino.example.com

# Registrierung — nach initialer Einrichtung auf false setzen
REGISTRATION_ENABLED=true

# SMTP — für Passwort-Reset E-Mails (optional)
# Ohne SMTP läuft der Demo-Modus (Token direkt in der API-Antwort)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=geheimesPasswort
SMTP_FROM=noreply@example.com

# Logging
# LOG_LEVEL: debug | info | warn | error  (Standard: info)
LOG_LEVEL=info
# LOG_FORMAT: text | json  (json empfohlen für Produktion / Log-Aggregatoren)
LOG_FORMAT=text
